    @(posedge clk); dec_addr_config = 8'd15; dec_data_config = 16'd256; // base[15]
    @(posedge clk); dec_addr_config = 8'd16; dec_data_config = 16'd256; // base[16]
    @(posedge clk); // extra cycle before table_sel change

    // symbol_table (table_sel = 2)
    dec_table_sel = 2'd2;
