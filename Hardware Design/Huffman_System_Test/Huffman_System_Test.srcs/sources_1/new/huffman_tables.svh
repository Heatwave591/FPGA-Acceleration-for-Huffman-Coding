task config_decoder_full();
begin
    dec_wr_en = 1;

    // first_code table (table_sel = 0)
    dec_table_sel = 2'd0;
    @(posedge clk); dec_addr_config = 8'd1; dec_data_config = 16'hFFFF; // first_code[1]
    @(posedge clk); dec_addr_config = 8'd2; dec_data_config = 16'hFFFF; // first_code[2]
    @(posedge clk); dec_addr_config = 8'd3; dec_data_config = 16'hFFFF; // first_code[3]
    @(posedge clk); dec_addr_config = 8'd4; dec_data_config = 16'hFFFF; // first_code[4]
    @(posedge clk); dec_addr_config = 8'd5; dec_data_config = 16'h0000; // first_code[5]
    @(posedge clk); dec_addr_config = 8'd6; dec_data_config = 16'h0800; // first_code[6]
    @(posedge clk); dec_addr_config = 8'd7; dec_data_config = 16'h1800; // first_code[7]
    @(posedge clk); dec_addr_config = 8'd8; dec_data_config = 16'h1A00; // first_code[8]
    @(posedge clk); dec_addr_config = 8'd9; dec_data_config = 16'hEC00; // first_code[9]
