    @(posedge clk); dec_addr_config = 8'd9; dec_data_config = 16'd21; // base[9]
    @(posedge clk); dec_addr_config = 8'd10; dec_data_config = 16'd22; // base[10]
    @(posedge clk); dec_addr_config = 8'd11; dec_data_config = 16'd240; // base[11]
