task config_decoder_full();
begin
    dec_wr_en = 1;

    // first_code table (table_sel = 0)
    dec_table_sel = 2'd0;
    @(posedge clk); dec_addr_config = 8'd1; dec_data_config = 16'h0000; // first_code[1]
    @(posedge clk); dec_addr_config = 8'd2; dec_data_config = 16'hFFFF; // first_code[2]
    @(posedge clk); dec_addr_config = 8'd3; dec_data_config = 16'hFFFF; // first_code[3]
