    @(posedge clk); dec_addr_config = 8'd6; dec_data_config = 16'd1; // base[6]
    @(posedge clk); dec_addr_config = 8'd7; dec_data_config = 16'd5; // base[7]
    @(posedge clk); dec_addr_config = 8'd8; dec_data_config = 16'd6; // base[8]
    @(posedge clk); dec_addr_config = 8'd9; dec_data_config = 16'd216; // base[9]
    @(posedge clk); dec_addr_config = 8'd10; dec_data_config = 16'd256; // base[10]
    @(posedge clk); dec_addr_config = 8'd11; dec_data_config = 16'd256; // base[11]
    @(posedge clk); dec_addr_config = 8'd12; dec_data_config = 16'd256; // base[12]
    @(posedge clk); dec_addr_config = 8'd13; dec_data_config = 16'd256; // base[13]
