    @(posedge clk); dec_addr_config = 8'd15; dec_data_config = 16'hFFFF; // first_code[15]
    @(posedge clk); dec_addr_config = 8'd16; dec_data_config = 16'hFFFF; // first_code[16]

    // base table (table_sel = 1)
    dec_table_sel = 2'd1;
    @(posedge clk); dec_addr_config = 8'd1; dec_data_config = 16'd0; // base[1]
    @(posedge clk); dec_addr_config = 8'd2; dec_data_config = 16'd1; // base[2]
    @(posedge clk); dec_addr_config = 8'd3; dec_data_config = 16'd1; // base[3]
